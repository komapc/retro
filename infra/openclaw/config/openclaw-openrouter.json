{
  "$schema": "https://openclaw.ai/schema/v2.json",

  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "openclaw-web-chat-token"
    },
    "controlUi": { "enabled": true },
    "trustedProxies": ["127.0.0.1", "172.18.0.1"]
  },

  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "sandbox": { "mode": "non-main" },
      "model": "litellm/claude-sonnet-4-6"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Assistant",
        "workspace": "/workspace",
        "model": "litellm/claude-sonnet-4-6",
        "identity": {
          "name": "Assistant",
          "theme": "Personal AI agent",
          "emoji": "🤖"
        },
        "skills": [
          "browser",
          "files",
          "terminal"
        ]
      },
      {
        "id": "researcher",
        "name": "Researcher",
        "workspace": "/workspace",
        "model": "litellm/cheap/smart",
        "identity": {
          "name": "Researcher",
          "theme": "Web research and analysis",
          "emoji": "🔍"
        },
        "skills": ["browser", "files"]
      },
      {
        "id": "coder",
        "name": "Coder",
        "workspace": "/workspace",
        "model": "litellm/cheap/code",
        "identity": {
          "name": "Coder",
          "theme": "Code and file/DB operations",
          "emoji": "💻"
        },
        "skills": ["files", "terminal"]
      }
    ]
  },

  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://host.docker.internal:4000/v1",
        "apiKey": "${LITELLM_MASTER_KEY}",
        "api": "openai-responses",
        "models": [
          { "id": "claude-sonnet-4-6",  "name": "Gemini 2.5 Flash (default)" },
          { "id": "claude-opus-4-6",    "name": "Gemini 2.5 Pro (smart)" },
          { "id": "cheap/mini",         "name": "Gemini Flash 1.5 8B (cheapest)" },
          { "id": "cheap/fast",         "name": "Gemini 2.0 Flash Lite (fast)" },
          { "id": "cheap/code",         "name": "Qwen 2.5 Coder 32B (code+files)" },
          { "id": "cheap/smart",        "name": "Qwen 2.5 72B (analysis)" },
          { "id": "cheap/deepseek",     "name": "DeepSeek Chat v3 (reasoning)" },
          { "id": "cheap/mistral",      "name": "Mistral Small 24B (general)" },
          { "id": "free/llama",         "name": "Llama 3.1 8B (free tier)" },
          { "id": "free/qwen",          "name": "Qwen 2.5 7B (free tier)" }
        ]
      }
    }
  },

  "bindings": [],

  "channels": {
    "telegram": { "enabled": false }
  },

  "browser": {
    "enabled": true,
    "headless": true
  }
}
