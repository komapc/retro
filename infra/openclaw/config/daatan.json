{
  "meta": {
    "description": "OpenClaw configuration for DAATAN (Mixed Strategy + Local Fallback)"
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": "google/gemini-2.0-flash-exp:free"
    },
    "definitions": {
      "main": {
        "id": "main",
        "label": "Corvus",
        "paths": { "base": "./agents/corvus" },
        "model": "google/gemini-2.0-flash-exp:free",
        "identity": {
          "name": "Corvus",
          "theme": "DAATAN forecasting platform",
          "emoji": "🔮"
        }
      },
      "devops": {
        "id": "devops",
        "label": "Infrastructure",
        "paths": { "base": "./agents/devops" },
        "model": "google/gemini-2.0-flash-exp:free",
        "identity": {
          "name": "DevOps Agent",
          "theme": "Infrastructure and deployment",
          "emoji": "🛠️"
        }
      },
      "qa": {
        "id": "qa",
        "label": "QA",
        "paths": { "base": "./agents/qa" },
        "model": "google/gemini-2.0-flash-exp:free",
        "identity": {
          "name": "QA Agent",
          "theme": "Testing and monitoring",
          "emoji": "🔬"
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": { "enabled": true }
    }
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      },
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      },
      "ollama:default": {
        "provider": "ollama",
        "mode": "api_key"
      }
    }
  }
}
