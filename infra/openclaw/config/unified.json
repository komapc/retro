{
  "$schema": "https://openclaw.ai/schema/v2.json",
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "openclaw-web-chat-token"
    },
    "controlUi": {
      "enabled": true
    },
    "trustedProxies": ["127.0.0.1", "172.18.0.1"]
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "sandbox": {
        "mode": "non-main"
      },
      "model": "qwen2.5:1.5b"
    },
    "list": [
      {
        "id": "daatan",
        "default": true,
        "name": "Corvus",
        "workspace": "/workspace/daatan",
        "identity": {
          "name": "Corvus",
          "theme": "DAATAN forecasting platform",
          "emoji": "🔮"
        },
        "skills": [
          "docker",
          "terraform",
          "github-actions",
          "nextjs",
          "daatan-deploy"
        ]
      }
    ]
  },
  "bindings": [],
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://host.docker.internal:11434/v1",
        "apiKey": "ollama-local",
        "api": "openai-responses",
        "models": [
          {
            "id": "qwen2.5:1.5b",
            "name": "Qwen 2.5 1.5B"
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": false
    }
  },
  "browser": {
    "enabled": true,
    "headless": true
  },
  "auth": {
    "profiles": {
      "ollama:default": {
        "provider": "ollama",
        "mode": "api_key"
      }
    }
  }
}
