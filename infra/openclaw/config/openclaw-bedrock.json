{
  "$schema": "https://openclaw.ai/schema/v2.json",

  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "openclaw-web-chat-token"
    },
    "controlUi": { "enabled": true },
    "trustedProxies": ["127.0.0.1", "172.18.0.1"]
  },

  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "sandbox": { "mode": "non-main" },
      "model": "bedrock/claude-haiku"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Assistant",
        "workspace": "/workspace",
        "model": "bedrock/claude-haiku",
        "identity": {
          "name": "Assistant",
          "theme": "Personal AI agent",
          "emoji": "🤖"
        },
        "skills": ["browser", "files", "terminal"]
      },
      {
        "id": "researcher",
        "name": "Researcher",
        "workspace": "/workspace",
        "model": "bedrock/claude-haiku",
        "identity": {
          "name": "Researcher",
          "theme": "Web research and analysis",
          "emoji": "🔍"
        },
        "skills": ["browser", "files"]
      },
      {
        "id": "coder",
        "name": "Coder",
        "workspace": "/workspace",
        "model": "bedrock/claude-sonnet",
        "identity": {
          "name": "Coder",
          "theme": "Code and file/DB operations",
          "emoji": "💻"
        },
        "skills": ["files", "terminal"]
      }
    ]
  },

  "models": {
    "providers": {
      "bedrock": {
        "api": "bedrock",
        "region": "us-east-1",
        "models": [
          {
            "id": "claude-haiku",
            "name": "Claude 3.5 Haiku (Bedrock) — default, cheapest",
            "modelId": "anthropic.claude-3-5-haiku-20241022-v1:0"
          },
          {
            "id": "claude-sonnet",
            "name": "Claude 3.5 Sonnet (Bedrock) — smarter, use sparingly",
            "modelId": "anthropic.claude-3-5-sonnet-20241022-v2:0"
          }
        ]
      }
    }
  },

  "bindings": [],

  "channels": {
    "telegram": { "enabled": false }
  },

  "browser": {
    "enabled": true,
    "headless": true
  }
}
