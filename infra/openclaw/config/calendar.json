{
  "meta": {
    "description": "OpenClaw configuration for Calendar (Mixed Strategy + Local Fallback)"
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": "google/gemini-2.0-flash-exp:free"
    },
    "definitions": {
      "main": {
        "id": "main",
        "label": "Calendar Agent",
        "paths": { "base": "./calendar-agent-bootstrap" },
        "model": "google/gemini-2.0-flash-exp:free",
        "identity": {
          "name": "Calendar Agent",
          "theme": "Year-shape (Vite, TypeScript)",
          "emoji": "📅"
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": { "enabled": true }
    }
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      },
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      },
      "ollama:default": {
        "provider": "ollama",
        "mode": "api_key"
      }
    }
  }
}
