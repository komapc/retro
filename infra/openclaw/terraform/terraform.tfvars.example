# Copy to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored — never commit it.

aws_region = "eu-central-1"

# Pick your instance size:
#   t3.medium  = 2 vCPU, 4 GB, ~$30/mo  — use WITHOUT LiteLLM, call OpenRouter directly
#   t3.large   = 2 vCPU, 8 GB, ~$60/mo  — recommended; runs OpenClaw + LiteLLM comfortably
#   t4g.large  = 2 vCPU, 8 GB, ~$37/mo  — ARM (change AMI arch to arm64 in main.tf)
ec2_instance_type = "t3.large"

ssh_key_name = "daatan-key"

# Your IP for SSH access (use /32 for single IP). Get with: curl -s ifconfig.me
allowed_ssh_cidr = "YOUR_IP/32"

# LiteLLM proxy auth key (OpenClaw → LiteLLM). Change from default.
litellm_master_key = "sk-change-me"
