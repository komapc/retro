{
  "meta": {
    "description": "Production configuration for DAATAN"
  },
  "agents": {
    "defaults": {
      "workspace": "/home/mark/projects/daatan"
    },
    "definitions": {
      "main": {
        "id": "main",
        "label": "Corvus",
        "paths": {
          "base": "./agents/corvus"
        },
        "model": "google/gemini-2.0-flash-exp:free"
      },
      "devops": {
        "id": "devops",
        "label": "Infrastructure",
        "paths": {
          "base": "./agents/devops"
        },
        "model": "google/gemini-2.0-flash-exp:free"
      },
      "qa": {
        "id": "qa",
        "label": "QA",
        "paths": {
          "base": "./agents/qa"
        },
        "model": "google/gemini-2.0-flash-exp:free"
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      },
      "ollama:default": {
        "provider": "ollama",
        "mode": "api_key"
      }
    }
  }
}
