{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListSnapshotBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::truthmachine-atlas-snapshots-<ACCOUNT_ID>"
    },
    {
      "Sid": "ReadWriteSnapshotObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObjectVersion",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::truthmachine-atlas-snapshots-<ACCOUNT_ID>/*"
    }
  ]
}
