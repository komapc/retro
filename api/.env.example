# Oracle API — required env vars
# Copy to .env and fill in values

# Shared secret for x-api-key header (generate with: openssl rand -hex 32)
ORACLE_API_KEY=change-me

# Path to retro data directory (contains leaderboard.json)
DATA_DIR=/home/ubuntu/truthmachine/data

# Optional: override leaderboard path directly
# LEADERBOARD_PATH=/home/ubuntu/truthmachine/data/leaderboard.json

# How often to re-read leaderboard.json (seconds)
LEADERBOARD_REFRESH_SECONDS=300

# Max articles to search per /forecast request
MAX_ARTICLES=5

# --- Shared with pipeline .env (copy from there) ---
SERPERDEV_KEY=
BRAVE_API_KEY=
OPENROUTER_API_KEY=
AWS_REGION=us-east-1
GATEKEEPER_MODEL=bedrock/amazon.nova-micro-v1:0
EXTRACTOR_MODEL=bedrock/amazon.nova-lite-v1:0
